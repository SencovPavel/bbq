# Скопируйте в .env.development.local для локальной разработки
# Vite подхватывает .env.development и .env.development.local

# Автовход тестовым пользователем при npm run dev (по умолчанию включено)
# VITE_DEV_AUTO_AUTH=false

# Должны совпадать с DEV_USER_* на бэкенде (picnic-backend/.env)
# VITE_DEV_USER_EMAIL=dev@kotyol.local
# VITE_DEV_USER_PASSWORD=dev12345
